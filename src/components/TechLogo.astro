---
import { Icon } from "astro-icon/components";

const { pack, name, followColorScheme } = Astro.props;
---

<span class="tech-logo">
  {
    !followColorScheme ? (
      <Icon name={`${pack ?? "skill-icons"}:${name.toLowerCase()}`} class="inline-icon" />
    ) : (
      <>
        <Icon name={`${pack ?? "skill-icons"}:${name.toLowerCase()}-dark`} class="inline-icon icon-dark" />
        <Icon name={`${pack ?? "skill-icons"}:${name.toLowerCase()}-light`} class="inline-icon icon-light" />
      </>
    )
  }
</span>
