---
import SiteLayout from "../../components/layout/SiteLayout.astro";
import AboutContent from "../../../content/about/about-me.mdx";

const pageTitle = "About — Vivek Raman";
const description =
  "Background, academics, skills, and how to get in touch — software engineer and CS graduate student.";
---

<SiteLayout
  pageTitle={pageTitle}
  description={description}
  wrapperClass="post-layout"
  breadcrumbs={[{ label: "About" }]}
>
  <article class="prose prose-article" aria-label="About">
    <AboutContent />
  </article>
</SiteLayout>
