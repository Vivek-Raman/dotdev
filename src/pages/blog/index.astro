---
import SiteLayout from "../../components/layout/SiteLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getCollection, type CollectionEntry } from "astro:content";

function dateSortKey(added: string | Date) {
  if (typeof added === "string") {
    const t = Date.parse(added);
    return Number.isNaN(t) ? 0 : t;
  }
  return added.getTime();
}

const all: CollectionEntry<"posts">[] = await getCollection("posts", ({ data }) => !data.hidden);

const featured = all
  .filter((p) => p.data.featuredOrder != null)
  .sort((a, b) => (a.data.featuredOrder ?? 0) - (b.data.featuredOrder ?? 0));

const rest = all
  .filter((p) => p.data.featuredOrder == null)
  .sort((a, b) => dateSortKey(b.data.added) - dateSortKey(a.data.added));

const pageTitle = "Blog — Vivek Raman";
const description = "Write-ups, case studies, and notes on software and projects.";
---

<SiteLayout
  pageTitle={pageTitle}
  description={description}
  wrapperClass="blog-index"
  breadcrumbs={[{ href: "/blog/", label: "Blog" }]}
>
  <header class="blog-index__header">
    <p class="blog-index__eyebrow">Writing</p>
    <h1 class="blog-index__title">Vivek's Blog</h1>
    <p class="blog-index__lede">Write-ups, projects, and opinion pieces talking about my journey through software development and AI.</p>
  </header>

  {
    featured.length > 0 && (
      <section class="blog-index__section" aria-labelledby="blog-featured-heading">
        <h2 id="blog-featured-heading" class="blog-index__section-title">
          Featured
        </h2>
        <ul class="featured__grid">
          {featured.map((entry, i) => (
            <PostCard entry={entry} stagger={i} accentOnHover />
          ))}
        </ul>
      </section>
    )
  }

  {rest.length === 0 && featured.length === 0 ? (
    <section class="blog-index__section" aria-label="Status">
      <p class="blog-index__empty">No posts published yet.</p>
    </section>
  ) : rest.length > 0 ? (
    <section class="blog-index__section" aria-labelledby="blog-archive-heading">
      <h2 id="blog-archive-heading" class="blog-index__section-title">
        {featured.length > 0 ? "All posts" : "Posts"}
      </h2>
      <ul class="featured__grid">
        {rest.map((entry, i) => (
          <PostCard entry={entry} stagger={i + featured.length} accentOnHover />
        ))}
      </ul>
    </section>
  ) : null}
</SiteLayout>
