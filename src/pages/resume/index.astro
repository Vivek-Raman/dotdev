---
import SiteLayout from "../../components/layout/SiteLayout.astro";

const RESUME_URL =
  "https://tgq565ix1n.ufs.sh/f/ck6yA5hy4Goxk7PfT3eBK20sWFeANrw9DqP6cvS1LmjbZifg";
const pageTitle = "Resume — Vivek Raman";
const description = "Résumé for Vivek Raman — software engineer.";
---

<SiteLayout
  pageTitle={pageTitle}
  description={description}
  wrapperClass="blog-index"
  breadcrumbs={[{ href: "/resume", label: "Resume" }]}
>
  <header class="blog-index__header">
    <p class="blog-index__eyebrow">Career</p>
    <h1 class="blog-index__title">Resume</h1>
    <p class="blog-index__lede">
      <a
        class="hero__link hero__link--ghost"
        href={RESUME_URL}
        target="_blank"
        rel="noopener noreferrer"
      >
        Download PDF
      </a>
    </p>
  </header>
  <div class="resume-frame">
    <iframe class="resume-frame__embed" src={RESUME_URL} title="Vivek Raman — resume" />
  </div>
</SiteLayout>
